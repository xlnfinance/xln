{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node copy-static-files.js && vite dev",
		"build": "node copy-static-files.js && vite build",
		"build:static": "node copy-static-files.js && vite build && echo 'Built for GitHub Pages deployment'",
		"native:build": "bun run build && cap sync",
		"native:ios": "bun run native:build && cap open ios",
		"native:android": "bun run native:build && cap open android",
		"native:sync": "cap sync",
		"native:doctor": "cap doctor",
		"preview": "node prepare-preview-assets.js && vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "node copy-static-files.js && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error && vite build",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "playwright test",
		"test:landing": "playwright test tests/landing.spec.ts",
		"test:fed": "playwright test tests/fed-chair-demo.spec.ts",
		"test:ui": "playwright test --ui"
	},
	"devDependencies": {
		"@capacitor/android": "^8.3.4",
		"@capacitor/cli": "^8.3.4",
		"@capacitor/ios": "^8.3.4",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"marked": "^16.4.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-multiselect": "^11.2.3",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"dependencies": {
		"@capacitor/app": "^8.1.0",
		"@capacitor/core": "^8.3.4",
		"@capacitor/device": "^8.0.2",
		"@capacitor/filesystem": "^8.1.2",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/keyboard": "^8.0.3",
		"@capacitor/local-notifications": "^8.2.0",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/push-notifications": "^8.1.1",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@scure/bip39": "^2.0.1",
		"@types/three": "^0.180.0",
		"dockview": "^4.9.0",
		"hash-wasm": "^4.12.0",
		"jsqr": "^1.4.0",
		"lucide-svelte": "^0.544.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"three": "^0.180.0"
	}
}
