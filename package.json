    "frozen-core:check": "bun tools/frozen-core.ts check",
    "frozen-core:tree": "bun tools/frozen-core.ts tree",
    "frozen-core:approve": "bun tools/frozen-core.ts approve",
    "frozen-core:add": "bun tools/frozen-core.ts add",
