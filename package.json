    "test:entity": "bun runtime/scripts/run-with-test-cleanup.ts --reason=entity --child-cwd=jurisdictions -- bunx hardhat test --grep entity",
    "check": "bun run check:src && bun run check:frontend-file-size && bun run check:frontend",
    "check:src": "bun run check:single-live-todo && bun run frozen-core:check && bun run check:e2e-categories && bun run check:runtime-doc-paths && bun run check:derive-delta-invariants && bun run check:no-weak-collections && bun run check:no-manual-delta-math && bun run check:no-active-infra-in-state-machine && bun run check:runtime-types",
