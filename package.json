    "deploy:fresh": "./deploy.sh --fresh",
    "deploy:prod": "./deploy.sh --remote root@xln.finance --push --frontend --fresh --production --reset-mesh",
    "deploy:prod:frontend": "./deploy.sh --remote root@xln.finance --push --frontend-only --production",
    "deploy:prod:runtime": "./deploy.sh --runtime-only --remote root@xln.finance --push --production --reset-mesh",
    "deploy:prod:runtime:reset": "./deploy.sh --runtime-only --remote root@xln.finance --push --production --reset-mesh",
    "deploy:prod:full": "./deploy.sh --remote root@xln.finance --push --frontend --fresh --production --reset-mesh",
    "deploy:prod:fresh": "./deploy.sh --remote root@xln.finance --push --frontend --fresh --production --reset-mesh",
    "deploy:qa": "./scripts/deploy-qa-evidence.sh --remote root@xln.finance",
    "deploy:qa:dry": "./scripts/deploy-qa-evidence.sh --remote root@xln.finance --dry-run",
