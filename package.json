{
  "name": "xlnfinance",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean-slate": "./scripts/dev/clean-slate.sh",
    "contracts:sync": "./scripts/sync-contract-artifacts.sh",
    "contracts:tron:compile": "cd jurisdictions && bun scripts/compile-tron.cjs --all",
    "dev:setup": "./scripts/dev/clean-slate.sh && ./scripts/sync-contract-artifacts.sh",
    "dev": "bun run dev:setup && RUNTIME_VERBOSE_LOGS=0 DEV_VERBOSE=0 ./scripts/dev/run-dev.sh",
    "dev:debug": "bun run dev:setup && XLN_LOG_LEVEL=debug XLN_LOG_SCOPES=entity,account,account.handler,orderbook,p2p RUNTIME_VERBOSE_LOGS=0 DEV_VERBOSE=0 ./scripts/dev/run-dev.sh",
    "dev:trace": "bun run dev:setup && XLN_LOG_LEVEL=trace XLN_LOG_FULL_PAYLOADS=1 RUNTIME_VERBOSE_LOGS=0 DEV_VERBOSE=0 ./scripts/dev/run-dev.sh",
    "dev:verbose": "bun run dev:setup && RUNTIME_VERBOSE_LOGS=1 DEV_VERBOSE=1 ./scripts/dev/run-dev.sh",
    "dev:anvil2": "./scripts/dev/run-anvil2.sh",
    "dev:no-relay": "cd frontend && vite dev",
    "relay": "bun runtime/relay/standalone-server.ts --port 9000",
    "watchtower": "bun runtime/watchtower/standalone-server.ts --port 9100",
    "build": "./scripts/build-runtime.sh",
    "start": "USE_ANVIL=true ANVIL_RPC=http://127.0.0.1:8545 XLN_MESH_RESET_ALLOWED=1 bun runtime/orchestrator/orchestrator.ts --host 127.0.0.1 --port 8080 --public-ws-base-url ws://127.0.0.1:8080 --rpc-url http://127.0.0.1:8545 --db-root ./db/local/mesh --mm --custody --allow-reset --custody-port 8087 --custody-daemon-port 8088 --wallet-url https://localhost:8084/app",
    "daemon:control": "bun runtime/scripts/daemon-control.ts",
    "custody": "bun custody/server.ts",
    "custody:prod": "bun runtime/scripts/start-custody-prod.ts",
    "dev:ci": "./dev-ci.sh",
    "serve": "USE_ANVIL=true ANVIL_RPC=http://127.0.0.1:8545 XLN_MESH_RESET_ALLOWED=1 bun runtime/orchestrator/orchestrator.ts --host 127.0.0.1 --port 8080 --public-ws-base-url ws://127.0.0.1:8080 --rpc-url http://127.0.0.1:8545 --db-root ./db/local/mesh --mm --custody --allow-reset --custody-port 8087 --custody-daemon-port 8088 --wallet-url https://localhost:8084/app",
    "serve:dev": "./scripts/sync-contract-artifacts.sh && ./scripts/build-runtime.sh && USE_ANVIL=true ANVIL_RPC=http://127.0.0.1:8545 XLN_MESH_RESET_ALLOWED=1 bun runtime/orchestrator/orchestrator.ts --host 127.0.0.1 --port 8080 --public-ws-base-url ws://127.0.0.1:8080 --rpc-url http://127.0.0.1:8545 --db-root ./db/local/mesh --mm --custody --allow-reset --custody-port 8087 --custody-daemon-port 8088 --wallet-url https://localhost:8084/app",
    "notify:done": "bash ./scripts/notify.sh 'Task complete' 'XLN Agent' 'All done'",
    "notify:fail": "bash ./scripts/notify.sh 'Task failed' 'XLN Agent' 'Check logs' 'Basso'",
    "test:e2e:notify": "bun run test:e2e:fast && bash ./scripts/notify.sh 'E2E fast passed' 'XLN Agent' || bash ./scripts/notify.sh 'E2E fast failed' 'XLN Agent' 'See report' 'Basso'",
    "test:e2e": "bun run test:e2e:fast",
    "test:e2e:fast": "bun runtime/scripts/run-e2e-fast.ts",
    "test:e2e:full": "bun runtime/scripts/run-e2e-parallel-isolated.ts --all --shards=16 --workers-per-shard=1 --max-mm-concurrency=1 --stack-timeout-ms=300000 --video=on --trace=off --screenshot=only-on-failure --max-failures=1",
    "test:e2e:all": "bun runtime/scripts/run-e2e-parallel-isolated.ts --all --shards=16 --workers-per-shard=1 --max-mm-concurrency=1 --stack-timeout-ms=300000 --video=on --trace=off --screenshot=only-on-failure --max-failures=1",
    "test:e2e:payment:smoke": "bunx playwright test tests/e2e-payment-smoke.spec.ts --project=chromium",
    "test:e2e:prod:payment": "PW_SKIP_WEBSERVER=1 PW_ONLY_CHROMIUM=1 PW_BASE_URL=https://xln.finance E2E_BASE_URL=https://xln.finance E2E_API_BASE_URL=https://xln.finance PW_VIDEO=retain-on-failure PW_TRACE=on-first-retry bunx playwright test tests/e2e-payment-smoke.spec.ts --project=chromium",
    "test:e2e:parallel:isolated": "bun runtime/scripts/run-e2e-parallel-isolated.ts",
    "test:e2e:parallel:max": "E2E_LONG=1 bun runtime/scripts/run-e2e-parallel-isolated.ts --shards=16 --workers-per-shard=1 --stack-timeout-ms=300000 --video=on --trace=off --screenshot=only-on-failure --max-failures=1",
    "test:e2e:parallel:long": "E2E_LONG=1 bun runtime/scripts/run-e2e-parallel-isolated.ts --shards=16 --workers-per-shard=1 --max-mm-concurrency=2 --video=on --trace=off --screenshot=only-on-failure --max-failures=1",
    "test:e2e:mvp": "bun runtime/scripts/run-e2e-parallel-isolated.ts --video=on --trace=off --screenshot=only-on-failure --max-failures=1",
    "test:e2e:core": "bun runtime/scripts/run-e2e-core.ts",
    "test:e2e:core:fast": "bun runtime/scripts/run-e2e-core.ts --skip-build",
    "test:e2e:coverage": "bun runtime/scripts/check-flow-e2e-coverage.ts",
    "test:persistence:cli": "bun runtime/scripts/persistence-wal-smoke.ts",
    "test:watchtower:smoke": "bun runtime/scripts/watchtower-smoke.ts",
    "test:rpc-settlement": "bun runtime/scripts/rpc-settlement-parity.ts",
    "soak:quick": "bun runtime/scripts/run-soak-gate.ts --profile=quick --iterations=2",
    "soak:swap10m": "bun runtime/scripts/run-soak-gate.ts --profile=swap --minutes=10",
    "soak:release": "bun runtime/scripts/run-soak-gate.ts --profile=release --minutes=240",
    "soak:capped-testnet": "bun runtime/scripts/run-soak-gate.ts --profile=release --minutes=1440",
    "prod:health": "bun runtime/scripts/prod-health-smoke.ts",
    "prod:health:capped-testnet": "bun runtime/scripts/prod-health-smoke.ts --expected-hubs=3 --require-hub-self-relay --expected-towers=1",
    "prod:smoke:local": "bun runtime/scripts/local-prod-smoke.ts",
    "prod:diagnose": "./scripts/prod-diagnose.sh",
    "security:audit-pack": "bun runtime/scripts/check-security-audit-pack.ts",
    "gate:quick": "bun runtime/scripts/run-release-gate.ts --profile=quick",
    "gate:ci": "bun runtime/scripts/run-release-gate.ts --profile=ci",
    "gate:release": "bun runtime/scripts/run-release-gate.ts --profile=release",
    "gate:capped-testnet": "bun runtime/scripts/run-capped-testnet-gate.ts",
    "gate:capped-testnet:preflight": "bun runtime/scripts/run-capped-testnet-gate.ts --skip-soak",
    "debug:receipts": "bun runtime/scripts/read-frame-receipts.ts",
    "debug:persistence": "bun runtime/scripts/inspect-persistence.ts",
    "bench:storage:hub": "bun runtime/scripts/bench-storage-hub.ts",
    "bench:swap:orderbook": "bun runtime/scripts/bench-swap-orderbook-tps.ts --swaps 100000 --warmup 10000 --min-tps 10000",
    "bench:swap:runtime": "bun runtime/scripts/bench-swap-runtime-tps.ts --swaps 25000 --warmup 2500 --min-tps 10000",
    "bench:swap:consensus": "bun runtime/scripts/bench-swap-hub-consensus-tps.ts --swaps 1000 --warmup 100 --min-tps 10000 --batch-size 100 --processes 4",
    "bench:swap:scenarios": "bun runtime/scripts/bench-swap-scenarios-tps.ts --swaps 25000 --warmup 2500 --min-tps 10000",
    "bench:radapter:hub10k": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=10000 --hot-percent=10 --memory=hot --seed-mode=bulk --chunk=1000 --traffic-rounds=10 --touch-per-round=100 --new-after-read=100 --rss-cap-mb=1024 --max-read-p99-ms=500 --max-durable-p99-ms=2000 --max-cold-open-ms=1000 --max-cold-read-ms=500",
    "bench:radapter:hub10k:rotation": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=10000 --hot-percent=10 --memory=hot --seed-mode=bulk --chunk=1000 --traffic-rounds=10 --touch-per-round=100 --new-after-read=100 --rotation-probe --rotation-epoch-bytes=1073741824 --rss-cap-mb=1024 --max-read-p99-ms=500 --max-durable-p99-ms=2000 --max-cold-open-ms=1000 --max-cold-read-ms=500 --max-snapshot-ms=5000 --max-epoch-seed-ms=5000 --max-rotation-probe-ms=10000",
    "bench:radapter:hub100k:hot10k": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=100000 --hot-accounts=10000 --memory=hot --seed-mode=bulk --chunk=5000 --traffic-rounds=10 --touch-per-round=100 --new-after-read=100 --rss-cap-mb=2048 --max-read-p99-ms=750 --max-durable-p99-ms=3000 --max-cold-open-ms=1500 --max-cold-read-ms=750",
    "bench:radapter:hub1m:assert": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=1000000 --hot-percent=1 --memory=hot --seed-mode=bulk --chunk=10000 --traffic-rounds=10 --touch-per-round=100 --new-after-read=100 --rss-cap-mb=24576 --max-read-p99-ms=1000 --max-durable-p99-ms=8000 --max-cold-open-ms=5000 --max-cold-read-ms=1000 --keep-db",
    "bench:radapter:hub1m:rotation": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=1000000 --hot-percent=1 --memory=hot --seed-mode=bulk --chunk=10000 --traffic-rounds=10 --touch-per-round=100 --new-after-read=100 --rotation-probe --rotation-epoch-bytes=1073741824 --rss-cap-mb=24576 --max-read-p99-ms=1000 --max-durable-p99-ms=8000 --max-cold-open-ms=5000 --max-cold-read-ms=1000 --max-snapshot-ms=180000 --max-epoch-seed-ms=180000 --max-rotation-probe-ms=360000 --keep-db",
    "bench:radapter:hub1m": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=1000000 --hot-percent=1 --memory=hot --seed-mode=bulk --chunk=10000 --traffic-rounds=10 --touch-per-round=100 --keep-db",
    "bench:radapter:hub1m:allmem": "bun --expose-gc runtime/scripts/bench-radapter-hub-1m.ts --accounts=1000000 --hot-percent=1 --memory=all --seed-mode=bulk --chunk=10000 --traffic-rounds=10 --touch-per-round=100 --keep-db",
    "test:scenarios:parallel:isolated": "bun runtime/scenarios/run.ts",
    "test:all:fast": "bun runtime/scripts/run-all-tests-fast.ts",
    "test:feedback:20": "bun runtime/scenarios/run.ts --set=smoke --workers=2",
    "test:all:quick": "bun runtime/scripts/run-all-tests-fast.ts --quick --skip-build --scenario-workers=2 --e2e-shards=1",
    "test:all:smoke": "bun runtime/scripts/run-all-tests-fast.ts --smoke --skip-build --scenario-workers=2 --e2e-shards=1",
    "test:system:parallel": "bun runtime/scripts/run-system-tests-parallel.ts",
    "test:system:parallel:stream": "bun runtime/scripts/run-system-tests-parallel.ts --stream",
    "test:e2e:flows": "bun runtime/scripts/run-e2e-parallel-isolated.ts --pw-project=chromium --pw-files=tests/e2e-user-journey.spec.ts,tests/e2e-rebalance-bar.spec.ts,tests/e2e-ahb-isolated.spec.ts,tests/e2e-multiroute-load.spec.ts",
    "dev:quick": "./dev-quick.sh",
    "dev:watch": "./dev-watch.sh",
    "dev:reset": "./reset-networks.sh",
    "test": "bun runtime/scripts/run-all-tests-fast.ts --quick --scenario-workers=2 --e2e-shards=1",
    "test:contracts": "bun run test:contracts:full",
    "test:contracts:full": "cd jurisdictions && bun run test",
    "build:static": "cd frontend && bun run build:static && echo '✅ Static build complete for GitHub Pages'",
    "build:deploy": "npm run build:static && echo '🚀 Ready for GitHub Pages deployment'",
    "native": "bun scripts/native/build-platforms.ts",
    "native:all": "bun scripts/native/build-platforms.ts all",
    "native:package": "bun scripts/native/build-platforms.ts all --package --smoke --best-effort",
    "native:mobile": "bun scripts/native/build-platforms.ts mobile",
    "native:mobile:package": "bun scripts/native/build-platforms.ts mobile --package",
    "native:ios": "bun scripts/native/build-platforms.ts ios --open",
    "native:ios:package": "bun scripts/native/build-platforms.ts ios --package",
    "native:android": "bun scripts/native/build-platforms.ts android --open",
    "native:android:package": "bun scripts/native/build-platforms.ts android --package",
    "native:desktop": "bun scripts/native/build-platforms.ts desktop --open",
    "native:desktop:smoke": "bun scripts/native/build-platforms.ts desktop --smoke",
    "native:extension": "bun scripts/native/build-platforms.ts extension",
    "deploy": "./deploy.sh",
    "deploy:chains:testnet": "cd jurisdictions && bun scripts/deploy-chain-matrix.cjs --profile=testnet --write-jurisdictions",
    "deploy:chains:mainnet": "cd jurisdictions && bun scripts/deploy-chain-matrix.cjs --profile=mainnet --yes --write-jurisdictions",
    "deploy:mainnets": "bun run deploy:chains:mainnet",
    "deploy:frontend": "./deploy.sh --frontend",
    "deploy:full": "./deploy.sh --frontend",
    "deploy:fresh": "./deploy.sh --fresh",
    "deploy:prod": "./deploy.sh --remote root@xln.finance --push --frontend --production",
    "deploy:prod:frontend": "./deploy.sh --remote root@xln.finance --push --frontend --production",
    "deploy:prod:runtime": "./deploy.sh --runtime-only --remote root@xln.finance --push --production",
    "deploy:prod:full": "./deploy.sh --remote root@xln.finance --push --frontend --production",
    "deploy:prod:fresh": "./deploy.sh --remote root@xln.finance --push --frontend --fresh --production",
    "test:contracts:r2r": "echo 'obsolete: direct unsafe R2R post-deploy script removed; use processBatch paths in e2e/scenarios'",
    "test:governance": "cd jurisdictions && npx hardhat test --grep governance",
    "test:entity": "cd jurisdictions && npx hardhat test --grep entity",
    "check": "bun run check:src && bun run check:frontend",
    "check:src": "bun run check:derive-delta-invariants && bun run check:no-weak-collections && bun run check:no-manual-delta-math && bun run check:no-active-infra-in-state-machine && bun run check:runtime-types",
    "check:frontend": "cd frontend && bun run check",
    "check:runtime-types": "bun x tsc -p tsconfig.runtime.json --noEmit",
    "check:no-weak-collections": "bun runtime/scripts/check-no-weak-collections.ts",
    "check:derive-delta-invariants": "bun tests/scripts/check-derive-delta-invariants.ts",
    "check:no-manual-delta-math": "bun runtime/scripts/check-no-manual-delta-math.ts",
    "check:no-active-infra-in-state-machine": "bun runtime/scripts/check-no-active-infra-in-state-machine.ts",
    "check:determinism": "bun runtime/scripts/check-determinism.ts",
    "soundcheck": "bun tools/soundcheck.ts",
    "visualcheck": "bun tools/visualcheck.ts",
    "build:tsc": "tsc",
    "watch": "tsc --watch",
    "env:build": "cd ./jurisdictions && npx hardhat compile",
    "env:run": "sh -c 'anvil --host 0.0.0.0 --port 8545 --chain-id 31337 --mixed-mining --block-time ${XLN_ANVIL_BLOCK_TIME:-1} --block-gas-limit 60000000 --code-size-limit 65536'",
    "env:deploy": "cd ./jurisdictions && npx hardhat ignition deploy ignition/modules/Depository.ts  --network localhost",
    "format": "prettier --write ./runtime",
    "check:prettier": "prettier --check ./runtime",
    "lint": "eslint ./runtime",
    "docs:governance": "echo 'See docs/governance-architecture.md for comprehensive governance documentation'",
    "demo": "echo 'See docs/governance-architecture.md for governance demo and examples'"
  },
